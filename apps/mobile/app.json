{
  "expo": {
    "name": "Nexi Locate",
    "slug": "nexi-locate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "nexilocate",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nexi.locate",
      "config": {
        "googleMapsApiKey": "AIzaSyB2Nc8a3Qg4IG__s_TOrDU0m1M8ka2-njI"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0E1A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.nexi.locate",
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyB2Nc8a3Qg4IG__s_TOrDU0m1M8ka2-njI"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      "expo-status-bar",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Nexi Locate needs your location to show nearby places and navigate.",
          "locationWhenInUsePermission": "Nexi Locate needs your location to show nearby places."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Nexi Locate needs camera access to take photos and record videos of places.",
          "microphonePermission": "Nexi Locate needs microphone access to record audio with videos.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Nexi Locate needs microphone access to record audio for reviews."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Nexi Locate needs access to your contacts to share places and invite friends."
        }
      ]
    ]
  }
}
